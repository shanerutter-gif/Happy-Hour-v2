{
  "version": 2,
  "crons": [
    { "path": "/api/loops-inactive", "schedule": "0 14 * * *" },
    { "path": "/api/daily-deals", "schedule": "0 14 * * *" }
  ],
  "redirects": [
    { "source": "/app-download", "destination": "https://apps.apple.com/us/app/spotd/id6760452388", "permanent": false }
  ],
  "rewrites": [
    { "source": "/spots/:slug+",              "destination": "/api/spots.js?slug=:slug+" },
    { "source": "/blog/:slug",                "destination": "/api/blog-post.js?slug=:slug" },
    { "source": "/sitemap-venues.xml",        "destination": "/api/sitemap-venues.js" },
    { "source": "/api/auth",                  "destination": "/api/auth.js" },
    { "source": "/api/loops-onboarding",      "destination": "/api/loops-onboarding.js" },
    { "source": "/api/loops-event",           "destination": "/api/loops-event.js" },
    { "source": "/api/loops-inactive",        "destination": "/api/loops-inactive.js" },
    { "source": "/api/daily-deals",           "destination": "/api/daily-deals.js" },
    { "source": "/api/stripe-checkout",       "destination": "/api/stripe-checkout.js" },
    { "source": "/api/stripe-billing-portal", "destination": "/api/stripe-billing-portal.js" },
    { "source": "/api/stripe-webhook",        "destination": "/api/stripe-webhook.js" },
    { "source": "/api/send-push",             "destination": "/api/send-push.js" }
  ]
}
